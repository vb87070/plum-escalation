{
  "name": "Gmail → Plum Escalation Dashboard",
  "nodes": [
    {
      "parameters": {
        "pollTimes": {
          "item": [{ "mode": "everyMinute" }]
        },
        "filters": {},
        "options": {}
      },
      "id": "gmail-trigger-node",
      "name": "Gmail Trigger",
      "type": "n8n-nodes-base.gmailTrigger",
      "typeVersion": 1,
      "position": [240, 300],
      "credentials": {
        "gmailOAuth2": {
          "id": "1",
          "name": "Gmail account"
        }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://plum-escalation-production.up.railway.app/webhook/ingest",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"source_channel\": \"gmail\",\n  \"source_message_id\": \"{{ $json.id || $json.messageId || 'gmail-' + Date.now() }}\",\n  \"received_at\": \"{{ $json.date || $json.internalDate || new Date().toISOString() }}\",\n  \"sender_name\": \"{{ ($json.from || '').replace(/<.*>/, '').trim() || 'Unknown' }}\",\n  \"sender_contact\": \"{{ (($json.from || '').match(/<(.+)>/) || [])[1] || $json.from || '' }}\",\n  \"raw_message\": \"{{ 'Subject: ' + ($json.subject || '(no subject)') + '\\\\n\\\\n' + ($json.text || $json.snippet || $json.body || '') }}\"\n}",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "http-request-gmail",
      "name": "Send to Plum Dashboard",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [500, 300]
    }
  ],
  "connections": {
    "Gmail Trigger": {
      "main": [
        [
          {
            "node": "Send to Plum Dashboard",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  },
  "tags": []
}
