{
  "name": "Gmail → Plum Escalation Dashboard",
  "nodes": [
    {
      "parameters": {
        "pollTimes": {
          "item": [{ "mode": "everyMinute" }]
        },
        "filters": {},
        "options": {
          "dataPropertyAttachmentsPrefixName": ""
        }
      },
      "id": "gmail-trigger-node",
      "name": "Gmail Trigger",
      "type": "n8n-nodes-base.gmailTrigger",
      "typeVersion": 1,
      "position": [240, 300],
      "credentials": {
        "gmailOAuth2": {
          "id": "1",
          "name": "Gmail account"
        }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:8000/webhook/ingest",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": []
        },
        "specifyBody": "json",
        "jsonBody": "={\n  \"source_channel\": \"gmail\",\n  \"source_message_id\": \"{{ $json.id }}\",\n  \"received_at\": \"{{ $json.date }}\",\n  \"sender_name\": \"{{ $json.from && $json.from.name ? $json.from.name : ($json.from && $json.from.value && $json.from.value[0] ? $json.from.value[0].address.split('@')[0] : 'Unknown') }}\",\n  \"sender_contact\": \"{{ $json.from && $json.from.value && $json.from.value[0] ? $json.from.value[0].address : '' }}\",\n  \"raw_message\": \"{{ ($json.subject ? 'Subject: ' + $json.subject + '\\\\n\\\\n' : '') + ($json.text || $json.snippet || '') }}\"\n}",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "http-request-gmail",
      "name": "Send to Plum Dashboard",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [500, 300]
    }
  ],
  "connections": {
    "Gmail Trigger": {
      "main": [
        [
          {
            "node": "Send to Plum Dashboard",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  },
  "tags": []
}
